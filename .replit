modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3003

[[ports]]
localPort = 5003
externalPort = 4200

[[ports]]
localPort = 5004
externalPort = 5000

[[ports]]
localPort = 5005
externalPort = 5173

[[ports]]
localPort = 5006
externalPort = 6000

[[ports]]
localPort = 5007
externalPort = 6800

[[ports]]
localPort = 5008
externalPort = 8008

[[ports]]
localPort = 5009
externalPort = 8099

[[ports]]
localPort = 5010
externalPort = 8080

[[ports]]
localPort = 5011
externalPort = 8000

[[ports]]
localPort = 5012
externalPort = 8081

[[ports]]
localPort = 23636
externalPort = 3001

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"
